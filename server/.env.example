PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@<cluster-host>/<db_name>?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_32_plus_character_secret
JWT_EXPIRES_IN=1d
CLIENT_URL=http://localhost:3000,http://localhost:4173
ADMIN_EMAIL=admin@system.com
ADMIN_PASSWORD=replace_with_a_strong_admin_password
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=300
STORAGE_PROVIDER=local
STORAGE_BUCKET=trust-nest-documents
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=http://127.0.0.1:9000
STORAGE_PUBLIC_BASE_URL=http://127.0.0.1:9000/trust-nest-documents
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin
STORAGE_FORCE_PATH_STYLE=true

# Python AI API
AI_API_URL=http://127.0.0.1:5001

# Ethereum / Web3
ETH_RPC_URL=https://sepolia.infura.io/v3/your_project_id
ETH_PRIVATE_KEY=0xyourwalletprivatekey
ETH_CONTRACT_ADDRESS=0xYourDeployedContractAddress
